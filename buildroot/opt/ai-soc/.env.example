# ==========================================
# Cybersecurity Analyst Agent Configuration
# ==========================================

# --- Alerts & Notifications ---
# The email addresses that will receive the weekly Markdown report.
# Separate multiple emails with a comma.
YOUR_EMAIL="admin@yourdomain.com, security@yourdomain.com"

# --- AI Provider Configuration ---
# Select your LLM Provider: "gemini", "openai", "claude", or "local"
LLM_PROVIDER="gemini"

# For Google Gemini (Vertex AI)
PROJECT_ID="your-gcp-project-id"
MODEL_ID="gemini-3-pro-preview"

# For OpenAI, xAI, or Local (Ollama/LM Studio)
# Example for Local: API_URL="http://localhost:11434/v1/chat/completions"
# Example for OpenAI: API_URL="https://api.openai.com/v1/chat/completions"
# Example for xAI: API_URL="https://api.x.ai/v1/chat/completions"
OPENAI_API_KEY="sk-..."
OPENAI_API_URL="https://api.openai.com/v1/chat/completions"
OPENAI_MODEL_ID="gpt-4o"

# For Anthropic Claude
CLAUDE_API_KEY="sk-ant-..."
CLAUDE_MODEL_ID="claude-3-5-sonnet-20240620"

# --- Server Log Paths ---
# Adjust these paths depending on your server environment (cPanel, Nginx, Apache, etc.)
# Leave empty or comment out if a specific service is not installed on your server.
APACHE_LOG_DIR="/var/log/apache2/" # e.g., /usr/local/apache/domlogs/ for cPanel
NGINX_LOG_DIR="/var/log/nginx/"    # Nginx error logs directory
SYSTEM_LOG_PATH="/var/log/syslog"  # e.g., /var/log/messages for RHEL/CentOS
MAIL_LOG_PATH="/var/log/mail.log"  # e.g., /var/log/maillog for RHEL/CentOS

# --- Database & Systemd Logs ---
# Path to MySQL/MariaDB slow query log.
# If empty, the script will attempt to auto-detect the path.
MYSQL_SLOW_LOG_PATH="/var/lib/mysql/slow-queries.log"

# Enable systemd journalctl analysis (requires journalctl to be installed)
# Set to "true" to enable.
USE_JOURNALCTL="true"

# --- Advanced Tuning ---
# Keywords to trigger log ingestion
KEYWORDS="error|warning|denied|blocked|failed|crashed|critical"

# Number of top distinct errors to send to the AI
TOP_N=20

# Max length of a single log line (prevents massive attack payloads from consuming context)
MAX_LINE_LENGTH=500

# Directory to save the auto-generated remediation bash scripts
REMEDIATION_DIR="/opt/ai-soc/remediation_scripts"

# Regex for logs to ignore (e.g. routine 404s, expected redirects)
NOISE_FILTER="favicon\.ico|robots\.txt|apple-touch-icon"